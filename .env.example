# ── Database ──
DATABASE_URL=postgresql://astro:astro@localhost:5432/astro_db

# ── AI Providers ──
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
ANTHROPIC_API_KEY=
AI_DAILY_BUDGET_USD=10.0

# ── JWT ──
JWT_SECRET=ZKT87rW7BXK5AxBBZkb18sxS7Kfl25FbVS8W1l82z5B887UnxiPllffPL9n8pMP0ac7b7o0V738QY0lQvwMQsQ
# При ротации: сначала добавь старый секрет сюда, потом смени JWT_SECRET выше.
# Через 7 дней (после истечения refresh-токенов) удали JWT_SECRET_PREV.
JWT_SECRET_PREV=

JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate Limiting ──
RATE_LIMIT_ANON=30/minute
RATE_LIMIT_AUTH=100/minute

# ── Ephemeris ──
EPHE_PATH=data/ephe

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_PREMIUM=price_...

# ── Google OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Email (Resend) ──
RESEND_API_KEY=re_...
FROM_EMAIL=onboarding@resend.dev
APP_URL=https://astreatime.ru
FRONTEND_URL=https://astreatime.ru

# ── Web Push (VAPID) ──
# Ключи генерируются один раз. Публичный ключ фронтенд получает через API,
# поэтому здесь нужны только серверные значения.
# VAPID_SUBJECT — контакт для push-сервисов: mailto:... или https://...
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@astreatime.ru

# ── CORS — через ALLOWED_ORIGINS (не хардкод) ──
# Список через запятую или JSON-массив
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000","https://astreatime.ru","https://www.astreatime.ru"]

# ── HTTPS redirect ──
# Установи true на продакшне — автоматически редиректит http → https
HTTPS_ONLY=false

# ── General ──
DEBUG=true
ENVIRONMENT=development

# ── Sentry ──
SENTRY_DSN=
